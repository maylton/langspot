# App Mode - Controls feature availability and behavior
# Options: 'development' | 'beta' | 'production'
# - development: allows demo mode, mock data, debug logging, and data reset
# - beta: requires real Supabase, disables demo mode, enables test accounts
# - production: strict mode, no testing features
# Defaults to 'development' locally, 'production' on production builds
VITE_APP_MODE=development

# Supabase Configuration
# Get these values from https://supabase.com/dashboard
# They should be kept in .env (not committed to git)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
